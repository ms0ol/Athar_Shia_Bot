args = "Shia Bot"

[[workflows.workflow]]
name = "Shia Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd project && python app.py"

[workflows.workflow.metadata]
outputType = "console"
